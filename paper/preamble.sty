%% ── Inline code shorthand ─────────────────────────────────
\newcommand{\code}[1]{\texttt{#1}}

%% ── Swift code file inclusion ─────────────────────────────
\newcommand{\codefile}[1]{\lstinputlisting[language=swift]{#1}}

%% ── Paper figure shorthand ────────────────────────────────
\newcommand{\paperfigure}[3][1.0]{%
  \begin{figure}[htbp]
    \centering
    \includegraphics[width=#1\linewidth]{#2}
    \caption{#3}
  \end{figure}
}

